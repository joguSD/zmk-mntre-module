CONFIG_USB_DEVICE_VID=0x1209
CONFIG_USB_DEVICE_PID=0x6d06
CONFIG_USB_DEVICE_MANUFACTURER="MNT"

CONFIG_SYS_CLOCK_HW_CYCLES_PER_SEC=125000000

# Enable clock control by default
CONFIG_CLOCK_CONTROL=y

# Enable reset by default
CONFIG_RESET=y

# Configure flash paritioning and allow writing to save settings
CONFIG_USE_DT_CODE_PARTITION=y
CONFIG_MPU_ALLOW_FLASH_WRITE=y
CONFIG_SETTINGS=y
CONFIG_NVS=y
CONFIG_SETTINGS_NVS=y
CONFIG_FLASH=y
CONFIG_FLASH_PAGE_LAYOUT=y
CONFIG_FLASH_MAP=y

# Output UF2 by default, native bootloader supports it.
CONFIG_BUILD_OUTPUT_UF2=y

# Enable USB
CONFIG_ZMK_USB=y
CONFIG_USB_HID_POLL_INTERVAL_MS=5

# Enable UART for sysctrl communication
CONFIG_SERIAL=y
CONFIG_UART_INTERRUPT_DRIVEN=y

# Enable float support in snprintf for battery display
CONFIG_CBPRINTF_FP_SUPPORT=y

# Enable Display
CONFIG_DISPLAY=y
CONFIG_ZMK_DISPLAY=n

# Enable Pointing
CONFIG_ZMK_POINTING=y

# Enable RGB
CONFIG_ZMK_RGB_UNDERGLOW=y
CONFIG_ZMK_RGB_UNDERGLOW_AUTO_OFF_IDLE=n
CONFIG_ZMK_RGB_UNDERGLOW_EXT_POWER=n
CONFIG_ZMK_RGB_UNDERGLOW_BRT_MAX=30
CONFIG_ZMK_RGB_UNDERGLOW_ON_START=n
CONFIG_ZMK_RGB_UNDERGLOW_EFF_START=3
CONFIG_ZMK_RGB_UNDERGLOW_HUE_START=78
CONFIG_ZMK_RGB_UNDERGLOW_SAT_START=50
CONFIG_ZMK_RGB_UNDERGLOW_BRT_START=15
